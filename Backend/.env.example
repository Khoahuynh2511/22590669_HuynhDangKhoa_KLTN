# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_ORGANIZATION=

# Graphiti OpenAI Configuration
GRAPHITI_SMALL_MODEL=gpt-4o-mini
GRAPHITI_MAIN_MODEL=gpt-4o-mini
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-large

# Database Configuration (Render PostgreSQL - primary)
# Lay External Database URL tu Render Dashboard > PostgreSQL > Connections
# Vi du: postgresql://user:pass@dpg-xxxxx.singapore-postgres.render.com/dbname
DATABASE_URL=postgresql://user:password@dpg-xxxxx.region-postgres.render.com/dbname

# Supabase (optional - vector search / embeddings only, NOT primary DB)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# JWT Configuration
# Generate a strong secret key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change_this_to_a_secure_random_string_for_production
JWT_EXPIRE=7

# Google OAuth2.0 Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
REDIS_DB=0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Agent Configuration
MAX_ITERATIONS=10
TIMEOUT=300

# FalkorDB Configuration
FALKORDB_HOST=
FALKORDB_PORT=49560
FALKORDB_USERNAME=
FALKORDB_PASSWORD=
FALKORDB_DATABASE=db1
FALKORDB_SSL=false

# MCP Server Configuration
MCP_SERVER_URL=http://localhost:8001
MCP_TIMEOUT=30
MCP_RETRY_COUNT=3
MCP_RETRY_BACKOFF=2.0

# Logging Configuration
LOG_LEVEL=INFO
LANGCHAIN_VERBOSE=True
LANGCHAIN_TRACING=False
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-assistant-backend
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
