# ==== Root .gitignore ====

# Database backups & dumps
*.backup
*.backup.gz
*.sql

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
.venv/
venv/
env/

# Node
node_modules/

# Environment variables
.env
.env.local
.env.*.local

# IDE & Editor
.vscode/
.cursor/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Angular
.angular/

# Build output
dist/
build/
out-tsc/

# Docker volumes
docker-data/

# Misc
.coverage
htmlcov/
